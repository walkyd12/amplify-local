{
  "name": "amplify-local",
  "version": "0.1.0",
  "description": "Local emulator for AWS Amplify Gen 2 — run your backend locally with zero AWS credentials",
  "type": "module",
  "bin": {
    "amplify-local": "./bin/amplify-local.js"
  },
  "main": "./src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/amplify-local.js start",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "amplify",
    "aws",
    "local",
    "emulator",
    "graphql",
    "dynamodb",
    "s3"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1027.0",
    "@aws-sdk/lib-dynamodb": "^3.1027.0",
    "@graphql-tools/schema": "^10.0.32",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "graphql": "^15.10.2",
    "jose": "^6.2.2",
    "ora": "^8.1.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0"
  }
}
